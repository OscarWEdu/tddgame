{
  "name": "fix-for-mysql",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n fe,be -c cyan,magenta \"vite --host\" \"dotnet run --project backend\"",
    "dev:fe": "vite --host",
    "dev:be": "dotnet run --project backend",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:e2e": "playwright test --project=e2e:*",
    "test:bdd": "bddgen && playwright test --project=bdd:*",
    "test:unit": "dotnet test tddgame.sln --verbosity normal",
    "test:api": "newman run postman/TDDGame_API_Tests.postman_collection.json -e postman/TDDGame.postman_environment.json --reporters cli"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "date-fns": "^4.1.0",
    "lucide": "^0.563.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.5.0",
    "sass": "1.77.6",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^15.15.0",
    "newman": "^6.2.2",
    "playwright-bdd": "^8.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.14.0",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  }
}
